{
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "dependencyDashboardLabels": [
    "GitHub Actions",
    "security",
    "renovate-bot"
  ],
  "dependencyDashboard": false,
  "gitAuthor": "wistia-github-bot <github-bot@wistia.com>",
  "prFooter": "This PR has been generated by [Renovate Bot](https://github.com/renovatebot/renovate).",
  "includePaths": [
    ".github/**"
  ],
  "labels": [
    "GitHub Actions",
    "security",
    "automated PR",
    "renovate-bot"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "pinDigest",
        "pin",
        "digest",
        "bump"
      ],
      "pinDigests": true,
      "minimumReleaseAge": "7 days",
      "prCreation": "not-pending"
    }
  ],
  "prHourlyLimit": 0,
  "pin": {
    "rebaseWhen": "behind-base-branch",
    "groupName": "Pin GitHub Actions Workflow Steps SHAs",
    "groupSlug": "pin-github-actions-workflow-steps-shas",
    "group": {
      "commitMessageTopic": "github-actions-workflow-steps-shas",
      "commitMessageExtra": ""
    }
  },
  "pinDigest": {
    "groupName": "Pin GitHub Actions Workflow Steps SHAs",
    "groupSlug": "pin-github-actions-workflow-steps-shas",
    "group": {
      "commitMessageTopic": "github-actions-workflow-steps-shas",
      "commitMessageExtra": ""
    }
  }
}
