{
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "dependencyDashboardLabels": [
    "GitHub Actions",
    "security",
    "renovate-bot"
  ],
  "dependencyDashboardTitle": "GitHub Actions Workflow Actions Dependency Dashboard",
  "gitAuthor": "wistia-github-bot <github-bot@wistia.com>",
  "prFooter": "This PR has been generated by [Renovate Bot](https://github.com/renovatebot/renovate).",
  "includePaths": [
    ".github/**"
  ],
  "labels": [
    "GitHub Actions",
    "security",
    "automated PR",
    "renovate-bot"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "pinDigest",
        "pin",
        "digest",
        "bump"
      ],
      "pinDigests": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\.github/workflows/.+\.yml$/"
      ],
      "matchStrings": [
        "repository: wistia/github-actions[\\s\\S]*?ref: (?<currentDigest>[a-f0-9]{40})"
      ],
      "depNameTemplate": "wistia/github-actions",
      "packageNameTemplate": "https://github.com/wistia/github-actions",
      "datasourceTemplate": "git-refs",
      "currentValueTemplate": "main",
      "versioningTemplate": "loose"
    }
  ],
  "prHourlyLimit": 0,
  "pin": {
    "rebaseWhen": "behind-base-branch",
    "groupName": "Pin GitHub Actions Workflow Steps SHAs",
    "groupSlug": "pin-github-actions-workflow-steps-shas",
    "group": {
      "commitMessageTopic": "github-actions-workflow-steps-shas",
      "commitMessageExtra": ""
    }
  },
  "pinDigest": {
    "groupName": "Pin GitHub Actions Workflow Steps SHAs",
    "groupSlug": "pin-github-actions-workflow-steps-shas",
    "group": {
      "commitMessageTopic": "github-actions-workflow-steps-shas",
      "commitMessageExtra": ""
    }
  }
}
